{
  "name": "auralis",
  "productName": "Auralis",
  "version": "1.6.0",
  "description": "Audiophile-grade music player and library manager — lossless-first, gapless, precise.",
  "main": "electron/main.js",
  "author": "Auralis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/QrowZK/MediaProj.git"
  },
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win nsis",
    "dist:win:portable": "electron-builder --win portable",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "audify": "^1.10.1",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "music-metadata": "^11.0.0"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.auralis.player",
    "publish": [
      {
        "provider": "github",
        "owner": "QrowZK",
        "repo": "MediaProj",
        "releaseType": "release"
      }
    ],
    "productName": "Auralis",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "native-addons/wasapi-exclusive/index.js",
      "native-addons/wasapi-exclusive/build/Release/*.node",
      "!**/*.map"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/audify/**",
      "native-addons/**"
    ],
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Auralis"
    }
  }
}
